# really.ai v2 — environment variable template
# Copy to .env and fill in real values before running.

# ---------------------------------------------------------------------------
# MongoDB (required)
# ---------------------------------------------------------------------------
# Full Atlas connection string, e.g.:
# mongodb+srv://<user>:<password>@cluster0.abc123.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority

# Target database name (default: really_ai)
MONGODB_DB_NAME=really_ai

# ---------------------------------------------------------------------------
# WhatsApp bridge (required)
# ---------------------------------------------------------------------------
# Internal URL of the Node.js whatsapp-web.js bridge process.
# Default: http://localhost:3001
WHATSAPP_BRIDGE_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# OpenAI (required)
# ---------------------------------------------------------------------------
# Used for GPT-4o conversations AND text-embedding-3-small profile embeddings.
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# VAPI — phone call intake & fallback consent calls (optional)
# ---------------------------------------------------------------------------
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# ---------------------------------------------------------------------------
# Resend — email introductions (optional)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM_DOMAIN=really.ai

# ---------------------------------------------------------------------------
# Matching thresholds
# ---------------------------------------------------------------------------
# Minimum cosine similarity score (0.0–1.0) for a match to be considered valid.
MATCH_SCORE_THRESHOLD=0.6

# Maximum number of matches to return per user.
MAX_MATCHES_PER_USER=5

# ---------------------------------------------------------------------------
# Public webhook base URL (required for VAPI callbacks and consent links)
# ---------------------------------------------------------------------------
# E.g. https://abc123.ngrok.io  or  https://api.really.ai
PUBLIC_BASE_URL=https://your-public-domain.example.com

# ---------------------------------------------------------------------------
# App behaviour
# ---------------------------------------------------------------------------
BOT_NAME=Really
DEBUG=false
